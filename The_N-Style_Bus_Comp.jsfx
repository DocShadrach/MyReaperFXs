        val = slider2 + dx * pixel_db;
        slider2 = floor(min(10, max(-30, val)) * 10 + 0.5) / 10; 
        slider_automate(slider2); 
    );
    drag_node == 0 ? (
        val = slider2 + dy * 0.5 * sens;
        slider2 = floor(min(10, max(-30, val)) * 10 + 0.5) / 10; 
