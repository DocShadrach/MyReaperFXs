    hover_node == 3 && slider4 ? ( slider5 = min(4, max(0.1, slider5 + w_dir * 0.01)); slider_automate(slider5); ); 
    hover_node == 4 ? ( slider6 = min(20, max(0, slider6 + w_dir * step)); slider_automate(slider6); ); 
    hover_node == 5 ? ( old_val = slider1; slider1 = min(20, max(-20, slider1 + w_dir * step)); slider_automate(slider1); slider13 ? ( slider8 = min(20, max(-20, slider8 - (slider1 - old_val))); slider_automate(slider8); ); );
    hover_node == 88 ? ( old_val = slider8; slider8 = min(20, max(-20, slider8 + w_dir * step)); slider_automate(slider8); slider13 ? ( slider1 = min(20, max(-20, slider1 - (slider8 - old_val))); slider_automate(slider1); ); );
    hover_node == 6 ? ( slider7 = min(100, max(0, slider7 + w_dir * 1.0)); slider_automate(slider7); );
