desc: The N-Style Bus Comp (DocShadrach)
// author: Doc Shadrach
// version: 1.0
// about: Faithful analog modeling inspired by 2254/33609 Diode Bridge units.
//
// Copyright (c) 2026 DocShadrach
// All rights reserved.
// Licensed for use inside REAPER for personal or professional projects only.
// Modification, copying, redistribution, or creating derivative works is prohibited.
// See LICENSE file in the repository for full terms.

// Hidden sliders (prefixed with -) for GUI-only operation
slider1:0<-20,20,0.1>-Input Trim (dB)
slider2:0<-30,10,0.1>-Threshold (dB)
slider3:3<1.5,20,0.1>-Ratio (x:1) [Limit > 6]
slider4:0<0,1,1{Auto (Dual Stage),Fixed}>-Release Mode
slider5:0.4<0.1,4,0.01>-Release Time (Fixed)
slider6:0<0,20,0.1>-Make-Up Gain (dB)
slider7:100<0,100,1>-Mix (%)
slider8:0<-20,20,0.1>-Output Trim (dB)

slider9:0.2<0,1,0.01>-Mic Pre Color (Iron+ClassA)
slider10:1<0,1,1{2254 (Vintage),33609 (Modern)}>-Model
slider11:0<0,1,1{Off,On}>-Sidechain HPF
slider12:0<0,1,1{Active,Bypassed}>-Soft Bypass
slider13:0<0,1,1{Unlinked,Linked}>-I/O Link
slider14:0<0,1,1{Dual Mono,Stereo Link}>-Detector Link

in_pin:left input
in_pin:right input
out_pin:left output
out_pin:right output

@init
gfx_ext_retina = 1;
log2db = 8.68588963806;
db2log = 0.11512925464970228; 
denorm = pow(10, -30); 
hum_freq = 50; 

// State Variables
last_out_l=0; last_out_r=0; last_raw_l=0; last_raw_r=0;
cv_state=0; cv_state_r=0; cv_lag_l=0; cv_lag_r=0;
auto_rel_slow=0; auto_rel_slow_r=0; 
dc_l_out=0; dc_r_out=0; dc_mid_l=0; dc_mid_r=0; 
last_play_state=0; env_follow=0; env_follow_r=0;

// Transformer & Filter States
flux_in_l=0; flux_in_r=0; flux_out_l=0; flux_out_r=0;
iron_filter_l=0; iron_filter_r=0; iron_filter_out_l=0; iron_filter_out_r=0; 
lp_alias_l=0; lp_alias_r=0;
hpf_x1=0; hpf_x2=0; hpf_y1=0; hpf_y2=0; hpf_x1_r=0; hpf_x2_r=0; hpf_y1_r=0; hpf_y2_r=0;
hum_phase1=0; noise_l_state=0; noise_r_state=0;
gr_meter_peak=0; gr_disp=0; in_meter_peak=0; in_disp=-100;

// Param Smoothing Targets
target_anom = slider9; smooth_anom = target_anom;
target_in_gain = pow(10, slider1/20); smooth_in_gain = target_in_gain;
target_makeup = pow(10, slider6/20); smooth_makeup = target_makeup;
target_out = pow(10, slider8/20); smooth_out = target_out;

drag_node = -1; hover_node = -1;

// --- DSP KERNELS ---

function calc_coeff(ms) ( exp(-1000.0 / (ms * srate)); );
function safety_saturate(x) ( x = max(-4.0, min(4.0, x)); x / (1 + abs(x*0.1)); );

function update_params() 
(
    target_in_gain = pow(10, slider1/20);
    target_makeup = pow(10, slider6/20);
    target_out = pow(10, slider8/20);
    thresh_db = slider2; ratio = slider3; 
    rel_mode = slider4; fixed_rel_ms = slider5 * 1000;
    mix_pct = slider7; mix_wet = mix_pct/100; mix_dry = 1.0 - mix_wet;
    target_anom = slider9; model_rev = slider10; 
    hpf_on = slider11; is_bypassed = slider12; link_mode = slider14;
    knee_width = 12.0; slope_factor = 1.0 - (1.0 / ratio); 
);

function apply_transformer_slew(x, last_x, drive) local(max_step, delta)
(
    max_step = (0.8 - (drive * 0.3)) * sr_comp; 
    delta = max(-max_step, min(max_step, x - last_x));
    last_x + delta;
);

function class_a_drive_pro(x, drive) local(bias, pos_drive, neg_drive)
(
    bias = 0.05 * drive; x += bias;
    pos_drive = 0.15 * drive; neg_drive = 0.12 * drive;
    x > 0 ? ( x = x / (1 + abs(x * pos_drive)); ) : ( x = x / (1 + abs(x * neg_drive)); );
    x - bias; 
);

function diode_bridge_pro(x, lin_gr, drive) local(bias, intermod)
(
    bias = (1.0 - lin_gr); 
    intermod = x * x * x * (bias * 0.2 * drive); 
    (x * lin_gr) - intermod; 
);

function diode_knee(x, width) ( (x > width*0.5) ? x : (x < -width*0.5) ? 0 : (sqr(x + width*0.5)) / (2 * width); );

@slider
update_params();

@block
sr_comp = 44100 / srate;
dc_alpha = 1.0 - exp(-2 * $pi * 5.0 / srate);
iron_lp_coeff = exp(-2 * $pi * 60.0 / srate);
cv_lag_coeff = exp(-1000.0 / (2.0 * srate)); 
alias_lp_coeff = exp(-2 * $pi * 16000.0 / srate);

// Smoothing: Fast for Color (5ms), Slow for Gain (30ms)
color_smooth_coeff = exp(-1.0 / (0.005 * srate)); 
gain_smooth_coeff = exp(-1.0 / (0.03 * srate));
meter_decay = exp(-1.0 / (0.3 * srate));
flux_decay = exp(-1000.0 / (50.0 * srate)); // Long memory for flux

att_ms = (model_rev == 0) ? 5.0 : 3.0; 
att_coeff = calc_coeff(att_ms);
auto_fast_coeff = calc_coeff(150); 
auto_slow_coeff = calc_coeff(1500);

// SC Filter Coeffs
freq = 100; wc = 2 * $pi * freq / srate; k_c = 1 / tan(wc / 2); sq_2 = 1.41421356;
norm_b = 1 / (1 + sq_2 * k_c + k_c * k_c);
b0_hpf = k_c * k_c * norm_b; b1_hpf = -2 * b0_hpf; b2_hpf = b0_hpf;
a1_hpf = 2 * (1 - k_c * k_c) * norm_b; a2_hpf = (1 - sq_2 * k_c + k_c * k_c) * norm_b;

(play_state != 0 && last_play_state == 0) ? (
    cv_state=0; cv_state_r=0; cv_lag_l=0; cv_lag_r=0; auto_rel_slow=0; auto_rel_slow_r=0;
    last_out_l=0; last_out_r=0; last_raw_l=0; last_raw_r=0;
    flux_in_l=0; flux_in_r=0; flux_out_l=0; flux_out_r=0;
    iron_filter_l=0; iron_filter_r=0; iron_filter_out_l=0; iron_filter_out_r=0;
    lp_alias_l=0; lp_alias_r=0; noise_l_state=0; noise_r_state=0;
    env_follow=0; env_follow_r=0; dc_l_out=0; dc_r_out=0; dc_mid_l=0; dc_mid_r=0;
    smooth_anom = target_anom; smooth_in_gain = target_in_gain;
    smooth_makeup = target_makeup; smooth_out = target_out;
);
last_play_state = play_state;

@sample
bypass_l = spl0; bypass_r = spl1;

// Parameter Interpolation
smooth_anom = (smooth_anom * color_smooth_coeff) + (target_anom * (1.0 - color_smooth_coeff));
smooth_in_gain = (smooth_in_gain * gain_smooth_coeff) + (target_in_gain * (1.0 - gain_smooth_coeff));
smooth_makeup = (smooth_makeup * gain_smooth_coeff) + (target_makeup * (1.0 - gain_smooth_coeff));
smooth_out = (smooth_out * gain_smooth_coeff) + (target_out * (1.0 - gain_smooth_coeff));

tol_l = 1.0 + (0.005 * smooth_anom); tol_r = 1.0 - (0.005 * smooth_anom); 
xtalk_coeff = 0.0004 * smooth_anom; 

// Input Gain + Denorm Injection
raw_l = spl0 * smooth_in_gain + denorm; 
raw_r = spl1 * smooth_in_gain + denorm;
dry_l = raw_l; dry_r = raw_r;

smooth_anom > 0 ? (
    raw_l = safety_saturate(raw_l);
    raw_r = safety_saturate(raw_r);
    
    // Slew Rate Limiting
    raw_l = apply_transformer_slew(raw_l, last_raw_l, smooth_anom); last_raw_l = raw_l;
    raw_r = apply_transformer_slew(raw_r, last_raw_r, smooth_anom); last_raw_r = raw_r;
    
    // Iron Transformer Logic (Left)
    iron_filter_l = (iron_filter_l * iron_lp_coeff) + (raw_l * (1.0 - iron_lp_coeff));
    flux_drive_l = smooth_anom * tol_l;
    hyst_l = (flux_in_l + iron_filter_l * 0.5) * 0.3 * flux_drive_l; 
    sat_l = raw_l + hyst_l;
    abs_sat_l = abs(sat_l);
    (abs_sat_l > 1.2) ? ( sat_l = 1.2 * (sat_l / abs_sat_l); ) : ( sat_l = sat_l / (1.0 + abs_sat_l * 0.3 * flux_drive_l); );
    flux_in_l = flux_in_l * flux_decay + sat_l * (1.0 - flux_decay);
    raw_l = sat_l; 

    // Iron Transformer Logic (Right)
    iron_filter_r = (iron_filter_r * iron_lp_coeff) + (raw_r * (1.0 - iron_lp_coeff));
    flux_drive_r = smooth_anom * tol_r;
    hyst_r = (flux_in_r + iron_filter_r * 0.5) * 0.3 * flux_drive_r; 
    sat_r = raw_r + hyst_r;
    abs_sat_r = abs(sat_r);
    (abs_sat_r > 1.2) ? ( sat_r = 1.2 * (sat_r / abs_sat_r); ) : ( sat_r = sat_r / (1.0 + abs_sat_r * 0.3 * flux_drive_r); );
    flux_in_r = flux_in_r * flux_decay + sat_r * (1.0 - flux_decay);
    raw_r = sat_r;
    
    // Inter-stage DC Block (Safety for Diode Bridge)
    dc_est_mid_l = (1.0 - dc_alpha) * dc_mid_l + dc_alpha * raw_l; dc_mid_l = dc_est_mid_l; raw_l -= dc_est_mid_l;
    dc_est_mid_r = (1.0 - dc_alpha) * dc_mid_r + dc_alpha * raw_r; dc_mid_r = dc_est_mid_r; raw_r -= dc_est_mid_r;
);

// True Feedback Detection
det_src_l = last_out_l; det_src_r = last_out_r;

// FIX: Filter AC signal BEFORE Rectification (abs)
hpf_on ? (
    // Left Channel
    hpf_out = b0_hpf*det_src_l + b1_hpf*hpf_x1 + b2_hpf*hpf_x2 - a1_hpf*hpf_y1 - a2_hpf*hpf_y2;
    hpf_x2=hpf_x1; hpf_x1=det_src_l + denorm; hpf_y2=hpf_y1; hpf_y1=hpf_out + denorm; 
    det_src_l = hpf_out;

    // Right Channel (Always process to maintain state for Stereo Link)
    hpf_out_r = b0_hpf*det_src_r + b1_hpf*hpf_x1_r + b2_hpf*hpf_x2_r - a1_hpf*hpf_y1_r - a2_hpf*hpf_y2_r;
    hpf_x2_r=hpf_x1_r; hpf_x1_r=det_src_r + denorm; hpf_y2_r=hpf_y1_r; hpf_y1_r=hpf_out_r + denorm; 
    det_src_r = hpf_out_r;
);

// Rectify
abs_l = abs(det_src_l);
abs_r = abs(det_src_r);

det_in_l = link_mode ? max(abs_l, abs_r) : abs_l;

det_db = 20 * log10(max(det_in_l, 0.000001)); 
overshoot = det_db - thresh_db;
target_gr = diode_knee(overshoot, knee_width) * slope_factor;

(target_gr > env_follow) ? (
    env_follow = target_gr + att_coeff * (env_follow - target_gr);
) : (
    rel_mode == 0 ? (
        (env_follow > auto_rel_slow) ? ( auto_rel_slow = env_follow; rel_c = auto_fast_coeff; ) : (
            auto_rel_slow = auto_rel_slow * auto_slow_coeff;
            rel_c = (env_follow > auto_rel_slow) ? auto_fast_coeff : auto_slow_coeff;
        );
    ) : ( auto_rel_slow = 0; rel_c = exp(-1000.0 / (slider5 * 1000.0 * srate)); );
    env_follow = target_gr + rel_c * (env_follow - target_gr);
);
env_follow = max(0, env_follow);
cv_lag_l = cv_lag_l * cv_lag_coeff + env_follow * (1.0 - cv_lag_coeff); cv_state = cv_lag_l;

link_mode ? (
    cv_state_r = cv_state; auto_rel_slow_r = auto_rel_slow;
    env_follow_r = env_follow; cv_lag_r = cv_lag_l;
) : (
    det_in_r = abs_r; // Already filtered if HPF was ON

    det_db_r = 20 * log10(max(det_in_r, 0.000001));
    overshoot_r = det_db_r - thresh_db;
    target_gr_r = diode_knee(overshoot_r, knee_width) * slope_factor;
    (target_gr_r > env_follow_r) ? (
        env_follow_r = target_gr_r + att_coeff * (env_follow_r - target_gr_r);
    ) : (
        rel_mode == 0 ? (
            (env_follow_r > auto_rel_slow_r) ? ( auto_rel_slow_r = env_follow_r; rel_c_r = auto_fast_coeff; ) : (
                auto_rel_slow_r = auto_rel_slow_r * auto_slow_coeff;
                rel_c_r = (env_follow_r > auto_rel_slow_r) ? auto_fast_coeff : auto_slow_coeff;
            );
        ) : ( auto_rel_slow_r = 0; rel_c_r = exp(-1000.0 / (slider5 * 1000.0 * srate)); );
        env_follow_r = target_gr_r + rel_c_r * (env_follow_r - target_gr_r);
    );
    env_follow_r = max(0, env_follow_r);
    cv_lag_r = cv_lag_r * cv_lag_coeff + env_follow_r * (1.0 - cv_lag_coeff); cv_state_r = cv_lag_r;
);

hum_phase1 += 2 * $pi * hum_freq / srate; (hum_phase1 > 2*$pi) ? hum_phase1 -= 2*$pi;
hum_ripple = sin(hum_phase1) * 0.00015 * smooth_anom;

lin_gr_l = exp(-cv_state * db2log); lin_gr_r = exp(-cv_state_r * db2log);

smooth_anom > 0 ? (
    lin_gr_l *= (1.0 + hum_ripple); lin_gr_r *= (1.0 - hum_ripple);
    out_l = diode_bridge_pro(raw_l, lin_gr_l, smooth_anom);
    out_r = diode_bridge_pro(raw_r, lin_gr_r, smooth_anom);
    lp_alias_l = lp_alias_l * alias_lp_coeff + out_l * (1.0 - alias_lp_coeff); out_l = lp_alias_l;
    lp_alias_r = lp_alias_r * alias_lp_coeff + out_r * (1.0 - alias_lp_coeff); out_r = lp_alias_r;
) : ( out_l = raw_l * lin_gr_l; out_r = raw_r * lin_gr_r; );

out_l *= smooth_makeup; out_r *= smooth_makeup;

smooth_anom > 0 ? (
    out_l = class_a_drive_pro(out_l, smooth_anom);
    out_r = class_a_drive_pro(out_r, smooth_anom);
    
    iron_filter_out_l = (iron_filter_out_l * iron_lp_coeff) + (out_l * (1.0 - iron_lp_coeff));
    hyst_l = (flux_out_l + iron_filter_out_l * 0.5) * 0.3 * smooth_anom; 
    sat_l = out_l + hyst_l;
    abs_sat_l = abs(sat_l);
    (abs_sat_l > 1.2) ? ( sat_l = 1.2 * (sat_l / abs_sat_l); ) : ( sat_l = sat_l / (1.0 + abs_sat_l * 0.3 * smooth_anom); );
    flux_out_l = flux_out_l * flux_decay + sat_l * (1.0 - flux_decay);
    out_l = sat_l;

    iron_filter_out_r = (iron_filter_out_r * iron_lp_coeff) + (out_r * (1.0 - iron_lp_coeff));
    hyst_r = (flux_out_r + iron_filter_out_r * 0.5) * 0.3 * smooth_anom; 
    sat_r = out_r + hyst_r;
    abs_sat_r = abs(sat_r);
    (abs_sat_r > 1.2) ? ( sat_r = 1.2 * (sat_r / abs_sat_r); ) : ( sat_r = sat_r / (1.0 + abs_sat_r * 0.3 * smooth_anom); );
    flux_out_r = flux_out_r * flux_decay + sat_r * (1.0 - flux_decay);
    out_r = sat_r;
    
    diff_xt = out_l - out_r;
    out_l -= diff_xt * xtalk_coeff; out_r += diff_xt * xtalk_coeff;
);

dc_est_l = (1.0 - dc_alpha) * dc_l_out + dc_alpha * out_l; dc_l_out = dc_est_l; out_l = out_l - dc_est_l;
dc_est_r = (1.0 - dc_alpha) * dc_r_out + dc_alpha * out_r; dc_r_out = dc_est_r; out_r = out_r - dc_est_r;

last_out_l = out_l; last_out_r = out_r;
mix_out_l = (out_l * mix_wet) + (dry_l * mix_dry); mix_out_r = (out_r * mix_wet) + (dry_r * mix_dry);
spl0 = mix_out_l * smooth_out; spl1 = mix_out_r * smooth_out;

(spl0 != spl0 || spl1 != spl1 || abs(spl0) > 20.0 || abs(spl1) > 20.0) ? (
    cv_state = 0; spl0 = 0; spl1 = 0; last_out_l = 0; last_out_r = 0;
);

gr_meter_peak = max(gr_meter_peak, cv_state); gr_meter_peak *= meter_decay;
in_meter_peak = max(in_meter_peak, max(abs(dry_l), abs(dry_r))); in_meter_peak *= meter_decay;
in_disp = in_disp * 0.8 + in_meter_peak * 0.2; gr_disp = gr_disp * 0.8 + gr_meter_peak * 0.2;
is_bypassed ? ( spl0 = bypass_l; spl1 = bypass_r; );

@gfx 650 350
slider10 == 0 ? ( gfx_clear = 0x303840; box_r = 0.20; box_g = 0.22; box_b = 0.25; acc_r = 0.9; acc_g = 0.35; acc_b = 0.2; ) : ( gfx_clear = 0x454D55; box_r = 0.28; box_g = 0.30; box_b = 0.35; acc_r = 0.2; acc_g = 0.7; acc_b = 0.9; );
txt_r=0.95; txt_g=0.95; txt_b=0.95; margin=10; header_h=40; status_h=20; meter_h=100;
controls_start_y = header_h + status_h + meter_h + margin; row_h = (gfx_h - controls_start_y - margin) / 2;
col_w = (gfx_w - (margin*2)) / 5; col_io_w = col_w * 0.85; link_w = col_w * 0.3;
graph_x = margin; graph_y = header_h + status_h + 10; graph_w = gfx_w - (margin*2); graph_h = meter_h - 10;

function map_db_to_x(db, w, min_db, max_db) ( norm = (db - min_db) / (max_db - min_db); min(w, max(0, norm * w)); );
function map_x_to_db(x_pixel, w, min_db, max_db) ( norm = x_pixel / w; min_db + (norm * (max_db - min_db)); );

function draw_visual_meter(x, y, w, h) (
    slider10 == 0 ? gfx_set(0.15, 0.17, 0.2, 1) : gfx_set(0.2, 0.22, 0.25, 1); gfx_rect(x, y, w, h); 
    gfx_set(0.4, 0.4, 0.4, 1); min_db = -60; max_db = 12; range = max_db - min_db;
    zero_pos_x = x + map_db_to_x(0, w, min_db, max_db);
    gfx_set(0.25, 0.1, 0.1, 0.5); bar_h = h/2 - 2; ghost_w = zero_pos_x - x;
    gfx_rect(x, y + bar_h + 4, ghost_w, bar_h);
    gfx_set(0.5, 0.5, 0.5, 1); i = -48; loop(5, lx = x + map_db_to_x(i, w, min_db, max_db); gfx_line(lx, y, lx, y+h); gfx_setfont(2, "Arial", 10); gfx_x = lx + 2; gfx_y = y + h - 12; sprintf(#lbl, "%d", i); gfx_drawstr(#lbl); i += 12; );
    gfx_set(0.7, 0.7, 0.7, 1); gfx_line(zero_pos_x, y, zero_pos_x, y+h); gfx_x = zero_pos_x + 2; gfx_y = y + h - 12; gfx_drawstr("0");
    in_db_val = 20 * log10(max(in_disp, 0.000001)); in_w = map_db_to_x(in_db_val, w, min_db, max_db);
    gfx_set(0.3, 0.7, 0.3, 0.9); gfx_rect(x, y, in_w, bar_h);
    thresh_x = x + map_db_to_x(slider2, w, min_db, max_db); gfx_set(acc_r, acc_g, acc_b, 0.8); gfx_rect(thresh_x, y, 2, h); 
    gfx_setfont(2); gfx_x = thresh_x + 4; gfx_y = y + 4; gfx_set(1, 1, 1, 1); sprintf(#t_lbl, "T: %.1f", slider2); gfx_drawstr(#t_lbl);
    gr_w_scaled = (gr_disp / range) * w; gfx_set(0.9, 0.2, 0.2, 1.0); 
    gr_disp > 0.05 ? ( final_gr_w = max(2, gr_w_scaled); gfx_rect(zero_pos_x - final_gr_w, y + bar_h + 4, final_gr_w, bar_h); );
    gr_disp > 0.1 ? ( gfx_setfont(1, "Arial", 30, 'b'); sprintf(#gr_str, "-%.1f dB", gr_disp); gfx_measurestr(#gr_str, tw, th); gfx_x = zero_pos_x - tw - 10; gfx_y = y + bar_h + 4 + (bar_h-th)/2; gfx_set(1, 1, 1, 1); gfx_drawstr(#gr_str); );
);

function draw_digital_param(x, y, w, h, title, val_str, is_active, node_id) (
    hover_node == node_id || drag_node == node_id ? gfx_set(box_r*1.4, box_g*1.4, box_b*1.4, 1) : gfx_set(box_r, box_g, box_b, 1);
    gfx_rect(x, y, w, h); drag_node == node_id ? gfx_set(acc_r, acc_g, acc_b, 1) : gfx_set(0, 0, 0, 1); gfx_rect(x, y, w, h, 0); 
    gfx_set(txt_r, txt_g, txt_b, 0.6); gfx_setfont(2, "Arial", 11, 'b'); gfx_measurestr(title, tw, th); gfx_x = x + (w-tw)/2; gfx_y = y + 8; gfx_drawstr(title);
    is_active ? gfx_set(txt_r, txt_g, txt_b, 1) : gfx_set(txt_r*0.5, txt_g*0.5, txt_b*0.5, 1);
    font_sz = min(28, w * 0.25); gfx_setfont(1, "Arial", font_sz, 'b'); gfx_measurestr(val_str, vw, vh); gfx_x = x + (w-vw)/2; gfx_y = y + (h/2) - (vh/2) + 6; gfx_drawstr(val_str);
);

function draw_mix_param(x, y, w, h, title, val_str, is_active, node_id) (
    gfx_set(txt_r, txt_g, txt_b, 0.5); gfx_setfont(2, "Arial", 11, 'b'); gfx_measurestr(title, tw, th); gfx_x = x + (w-tw)/2 + 20; gfx_y = y + 8; gfx_drawstr(title);
    is_active ? gfx_set(txt_r, txt_g, txt_b, 1) : gfx_set(0.4, 0.4, 0.4, 1);
