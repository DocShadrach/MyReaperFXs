    state ? (str=label_on; gfx_set(1,1,1,1)) : (str=label_off; gfx_set(0.6,0.6,0.6,1));
    gfx_setfont(3, "Arial", 14, 'b'); gfx_measurestr(str, sw, sh); gfx_x = x + (w-sw)/2; gfx_y = y + (h/2); gfx_drawstr(str);
);

