        slider_automate(slider2); 
    );
    hover_node == 99 ? ( slider12 = !slider12; slider_automate(slider12); update_params(); );
    hover_node == 98 ? ( slider10 = !slider10; slider_automate(slider10); update_params(); );
    hover_node == 87 ? ( slider14 = !slider14; slider_automate(slider14); update_params(); ); 
    hover_node == 97 ? ( slider13 = !slider13; slider_automate(slider13); );
    hover_node == 2 ? ( slider4 = !slider4; slider_automate(slider4); );
    hover_node == 8 ? ( slider11 = !slider11; slider_automate(slider11); );
